# ============================================================================
# Agility CMS (Required)
# Get these from API Keys page: https://manager.agilitycms.com/settings/apikeys
# ============================================================================
AGILITY_GUID=
AGILITY_API_FETCH_KEY=
AGILITY_API_PREVIEW_KEY=
AGILITY_SECURITY_KEY=

# Comma-separated, no spaces (e.g. en-us,fr-ca). Sandbox default: en-us
AGILITY_LOCALES=en-us
AGILITY_SITEMAP=website

# Cache durations in seconds
AGILITY_FETCH_CACHE_DURATION=120
AGILITY_PATH_REVALIDATE_DURATION=10

# ============================================================================
# Stripe (Required for e-commerce)
# Get from https://dashboard.stripe.com/test/apikeys
# STRIPE_WEBHOOK_SECRET is generated when you create the webhook endpoint
# ============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Public URL of the deployed site — used for Stripe redirects and magic links
# Local: http://localhost:3000  |  Vercel: https://<project>.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================================
# Resend (Required for magic-link auth on /account)
# Get API key from https://resend.com/api-keys
# For testing you can use RESEND_FROM_EMAIL=onboarding@resend.dev
# ============================================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ============================================================================
# Vercel Blob (Required — used by ABTestHero / media uploads)
# Create a Blob store in Vercel dashboard → Storage; token auto-injected
# in Vercel deployments. For local dev, copy the token here.
# ============================================================================
BLOB_READ_WRITE_TOKEN=

# ============================================================================
# Vercel Build Hook (Required for CMS-triggered rebuilds)
# Create in Vercel → Project Settings → Git → Deploy Hooks
# Also configure this URL as a webhook in Agility CMS
# ============================================================================
BUILD_HOOK_URL=

# ============================================================================
# PostHog (Optional — analytics & feature flags)
# Get from https://app.posthog.com/settings/api-keys
# ============================================================================
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================================================
# Azure OpenAI (Optional — only needed if using AI chat/agent features)
# ============================================================================
AZURE_AI_RESOURCE=
AZURE_AI_DEPLOYMENT=
AZURE_AI_KEY=

# ============================================================================
# Algolia (Not used in this sandbox — search is disabled)
# Uncomment and fill in only if you re-enable search
# ============================================================================
# ALGOLIA_APP_ID=
# ALGOLIA_SEARCH_API_KEY=
